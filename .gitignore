# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Build outputs
dist/
build/
.next/
.nuxt/
out/
.cache/

# Test coverage (build output — must never be committed)
coverage/
**/coverage/
*.lcov

# Environment variables / Local configuration
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
*.env
!.env.example
!*.env.example

# Secrets / credentials — NEVER commit
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
id_rsa
id_rsa.*
*.keystore
*credentials*.json
service-account*.json
secrets.json
secrets.*.json

# Terraform — state & tfvars hold PLAINTEXT secrets (apply this everywhere)
**/.terraform/
*.tfstate
*.tfstate.*
*.tfvars
*.tfvars.json
!*.tfvars.example
crash.log
crash.*.log
override.tf
override.tf.json
.terraform.tfstate.lock.info

# Security scan / SBOM outputs (can leak internal detail)
sbom*.json
trivy-results*.json
*.sarif

# Stray downloaded CLIs / binaries — must never be committed (size + supply chain)
minikube-*
kubectl-*
*-linux-amd64
*-darwin-amd64
*-windows-amd64
*.tar.gz
*.zip

# Debug/Log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.eslintcache
.stylelintcache

# IDEs and Editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
