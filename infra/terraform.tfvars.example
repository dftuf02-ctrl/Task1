# Copy to terraform.tfvars (gitignored) and fill in real values, OR set
# them as environment variables instead:
#   $env:TF_VAR_supabase_url      = "https://xxxx.supabase.co"
#   $env:TF_VAR_supabase_anon_key = "sb_publishable_xxx"
#
# Only the external Supabase credentials are needed here. JWT signing
# secrets are generated by Terraform (see secrets.tf) and never stored
# in any file.

supabase_url      = "https://your-project-id.supabase.co"
supabase_anon_key = "your-supabase-anon-key"
