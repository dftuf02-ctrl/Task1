{
  "name": "task-management-api",
  "version": "1.0.0",
  "description": "Production-ready Task Management REST API with Express.js and Supabase",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "worker": "node worker.js",
    "worker:dev": "nodemon worker.js",
    "lint": "eslint src/ server.js --ext .js",
    "lint:fix": "eslint src/ server.js --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" server.js",
    "test": "jest --coverage --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --coverage --forceExit",
    "test:e2e": "jest tests/integration --coverage --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "loadtest:auth": "k6 run ../loadtest/auth.js",
    "loadtest:tasks": "k6 run ../loadtest/tasks.js"
  },
  "keywords": [
    "task-management",
    "rest-api",
    "express",
    "supabase"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-node": "^11.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
