# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
# REQUIRED in production — the BACKEND must use the service-role key, never the
# anon key. With RLS locked down (migration 004), the anon key grants nothing.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Anon key is for the browser/frontend only (optional for the backend).
SUPABASE_ANON_KEY=your-supabase-anon-key

# JWT secrets — REQUIRED in every environment (no defaults). Use strong random
# values, e.g.  openssl rand -hex 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# HMAC key for the tamper-evident audit hash-chain. Optional — falls back to
# JWT_ACCESS_SECRET if unset. Set a dedicated value in production so rotating
# the JWT secret never breaks audit-log verification.  openssl rand -hex 48
AUDIT_HMAC_KEY=

# CORS
CORS_ORIGIN=http://localhost:5173

# Set when running behind a proxy/ingress so req.ip is the real client IP
# (otherwise rate limiting buckets everyone on the proxy address).
# Number of trusted hops, or 'loopback', etc. Defaults to 1 in production.
TRUST_PROXY=1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Redis (required for rate limiting and the background report queue)
REDIS_URL=redis://localhost:6379

# Background report queue / worker
REPORT_QUEUE_ATTEMPTS=3
REPORT_WORKER_CONCURRENCY=2
REPORT_PROCESSING_DELAY_MS=3000
# Demo only: probability (0..1) a job fails to showcase retries. Keep 0 normally.
REPORT_FAIL_RATE=0

# Email notifications (leave SMTP_URL empty to use the dev JSON transport)
SMTP_URL=
EMAIL_FROM=TaskFlow <no-reply@taskflow.local>

# Logging
LOG_LEVEL=info
